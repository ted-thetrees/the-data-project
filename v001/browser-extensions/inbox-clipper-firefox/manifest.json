{
  "manifest_version": 2,
  "name": "Inbox Clipper",
  "version": "2.1",
  "description": "Save current page to Teable Inbox",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "https://teable.ifnotfor.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_icon": {
      "48": "icon.svg"
    },
    "default_popup": "popup.html",
    "default_title": "Save to Inbox"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "48": "icon.svg"
  }
}
