{
  "manifest_version": 3,
  "name": "Inbox Clipper",
  "version": "2.0",
  "description": "Save current page to Teable Inbox",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://teable.ifnotfor.com/*"
  ],
  "action": {
    "default_icon": {
      "48": "icon.png"
    },
    "default_popup": "popup.html",
    "default_title": "Save to Inbox"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
